{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ],
    "crons": [
        {
            "path": "/jobs/process-next",
            "schedule": "*/1 * * * *"
        }
    ],
    "env": {
        "PYTHONPATH": "/var/task"
    }
}